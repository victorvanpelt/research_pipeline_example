# Ignore everything by default...
*

# ...but keep the project scaffolding
!.gitignore
!.gitattributes
!makefile.mak
!Makefile
!AGENTS.md
!README.md
!LICENSE

# 0_data: keep the folder, the shared synthetic example CSV, and its codebook.
# Real raw data is intentionally NOT shared here (add it locally; it stays ignored).
!0_data/
!0_data/.gitkeep
!0_data/gen_ai_earnings.csv
!0_data/codebook.md

# 1_code: keep the folder and all code (the scripts are the point of the repo),
# but not the artifacts rendering code.qmd leaves behind
!1_code/
!1_code/**
1_code/*.pdf
1_code/*.html
1_code/*_files/

# 2_process: keep the folder but none of its intermediate contents
!2_process/
!2_process/.gitkeep

# 3_output: keep the folder and all shared outputs (tables, figures)
!3_output/
!3_output/**

# 4_drafts: keep the sources, the materials, and the rendered PDFs;
# render intermediates (.tex, .html, .aux, *_files/, ...) stay ignored.
!4_drafts/
!4_drafts/*.qmd
!4_drafts/*.bib
!4_drafts/*.pdf
!4_drafts/materials/
!4_drafts/materials/**
!testdir/file.txt
